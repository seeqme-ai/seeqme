# Server Configuration
PORT=8080
ENV=development

# Database 
DATABASE_URL=

# JWT
JWT_SECRET=your-secret-key-change-in-production

# AI Providers (Optional - Configure based on usage)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Cloudinary (Required for file uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Cloudflare (Required for domain management)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Stripe (Required for payments)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=


# Hedera x402 Payment (mainnet)
# HBAR amount is computed automatically from live CoinGecko HBAR/NGN rate — no amount env var needed
HEDERA_NETWORK=mainnet
HEDERA_PAYMENT_ACCOUNT_ID=0.0.YOUR_ACCOUNT_ID
HEDERA_PAYMENT_EVM_ADDRESS=0xYOUR_EVM_ADDRESS
# Shared secret with hedera-agent: openssl rand -hex 32
AGENT_SECRET=generate-with-openssl-rand-hex-32
